# ====================================================================
# PowerShell Environment Whitelist Profile
# Default Behavior: Ignore everything, explicitly track chosen items
# ====================================================================

# 1. Global Block (Ignore absolutely everything by default)
*

# 2. Root Files to Track
!.gitignore
!Microsoft.PowerShell_profile.ps1

# 3. Directory Gates (Un-ignore folders so Git can step inside them)
!Config/
!Functions/
!Modules/
!Themes/
!Utilities/

# 4. Deep Content Whitelists (Track all nested files/subfolders)
!Config/**
!Functions/**
!Themes/**
!Utilities/**

# 5. Whitelist Exceptions (Re-ignore specific subfolders and contents)
Functions/logs/

# 6. Specific Module Whitelist
!Modules/Optimize-PSX/**
!Modules/Rename-MediaFile/**
